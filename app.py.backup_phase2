@app.route("/admin/toggle-ban", methods=["POST"])
def admin_toggle_ban():
    if not is_admin():
        return jsonify({"error": "admin required"}), 403

    data = request.get_json() or {}
    username = data.get("username")

    if username == ADMIN_NAME:
        return jsonify({"error": "main admin cannot be banned"}), 400

    conn = db()

    user = conn.execute(
        "SELECT * FROM users WHERE username = ?",
        (username,)
    ).fetchone()

    if not user:
        conn.close()
        return jsonify({"error": "user not found"}), 404

    if user["role"] == "admin":
        conn.close()
        return jsonify({"error": "admins cannot be banned"}), 400

    new_status = 0 if user["banned"] else 1

    conn.execute(
        "UPDATE users SET banned = ? WHERE username = ?",
        (new_status, username)
    )

    conn.commit()
    conn.close()

    log_action(session["user"], "ban_toggle", username, "banned=" + str(new_status))

    socketio.emit("admin_users_changed")

    return jsonify({"ok": True, "banned": new_status})


@app.route("/admin/set-role", methods=["POST"])
def admin_set_role():
    if not is_admin():
        return jsonify({"error": "admin required"}), 403

    data = request.get_json() or {}

    username = data.get("username")
    role = data.get("role")

    if role not in ["user", "mod", "admin"]:
        return jsonify({"error": "invalid role"}), 400

    if username == ADMIN_NAME and role != "admin":
        return jsonify({"error": "main admin must stay admin"}), 400

    conn = db()

    exists = conn.execute(
        "SELECT * FROM users WHERE username = ?",
        (username,)
    ).fetchone()

    if not exists:
        conn.close()
        return jsonify({"error": "user not found"}), 404

    conn.execute(
        "UPDATE users SET role = ? WHERE username = ?",
        (role, username)
    )

    conn.commit()
    conn.close()

    log_action(session["user"], "role_set", username, role)

    socketio.emit("admin_users_changed")

    return jsonify({"ok": True})


@app.route("/admin/reset-password", methods=["POST"])
def admin_reset_password():
