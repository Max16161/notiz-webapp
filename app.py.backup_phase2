    if username == ADMIN_NAME:
        return jsonify({"error": "main admin password should be changed in account settings"}), 400

    conn = db()

    exists = conn.execute(
        "SELECT * FROM users WHERE username = ?",
        (username,)
    ).fetchone()

    if not exists:
        conn.close()
        return jsonify({"error": "user not found"}), 404

    conn.execute(
        "UPDATE users SET password = ? WHERE username = ?",
        (generate_password_hash(new_password), username)
    )

    conn.commit()
    conn.close()

    log_action(session["user"], "password_reset", username, "")

    return jsonify({"ok": True})


