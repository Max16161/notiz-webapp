@socketio.on("send_message")
def socket_send_message(data):
    user = current_user()

    if not user:
        return

    if user["banned"]:
        emit("send_error", {"error": "Du bist gebannt."})
        return

    text = (data.get("text") or "").strip()
    channel = data.get("channel", "allgemein")

    if not can_access_channel(channel):
        emit("send_error", {"error": "Kein Zugriff auf diesen Raum."})
        return

    if not text:
        return

    conn = db()

    cur = conn.execute(
        "INSERT INTO messages (user, text, channel) VALUES (?, ?, ?)",
        (user["username"], text, channel)
    )

    msg_id = cur.lastrowid

    row = conn.execute("""
        SELECT
            messages.id,
            messages.user,
            messages.text,
            messages.created,
            messages.channel,
            COALESCE(users.role, 'user') AS role,
            COALESCE(users.avatar, '✊') AS avatar
        FROM messages
        LEFT JOIN users ON users.username = messages.user
        WHERE messages.id = ?
    """, (msg_id,)).fetchone()

    conn.execute(
        "INSERT OR REPLACE INTO presence (user, last_seen) VALUES (?, CURRENT_TIMESTAMP)",
        (user["username"],)
    )

    conn.commit()
    conn.close()

    socketio.emit("new_message", dict(row))


